# Server environment variables - DEVELOPMENT ONLY
# Copy from .env.example and set your real values
# DO NOT COMMIT THIS FILE

# 基本設定
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Vertex AI / Gemini 設定
USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-dev-project-id
VERTEX_AI_LOCATION=asia-northeast1
VERTEX_AI_MODEL=gemini-2.5-flash
# 必要に応じて API キー（Developer API を使う場合）
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# 画像・診断
MAX_IMAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3

# 機能フラグ
# 拡張診断（年代・性別推定）を有効化/無効化
ENHANCED_DIAGNOSIS_ENABLED=true

# セキュリティ・レート制限
API_KEY=dev-api-key-placeholder
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_DIAGNOSIS=10
RATE_LIMIT_BURST=5

# ログ
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
