# Google Cloud環境変数設定
# パーソナルカラー診断アプリ用

# Google Cloud & Vertex AI設定
GOOGLE_CLOUD_PROJECT=personal-color-469007
VERTEX_AI_LOCATION=asia-northeast1
VERTEX_AI_MODEL=gemini-2.5-flash

# API設定
API_MAX_TOKENS=1000
API_TEMPERATURE=0.3
API_TOP_P=0.8
API_TOP_K=40

# アプリケーション設定
APP_ENV=development
APP_LOG_LEVEL=INFO

# セキュリティ設定
# 実際の使用時は適切な値に変更してください
API_SECRET_KEY=your-secret-key-here
