# Production Environment Configuration for Personal Color Diagnosis API
# DO NOT COMMIT THIS FILE WITH REAL VALUES
# Copy from .env.example and set production values

# Application Settings
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS Settings
ALLOWED_ORIGINS=*

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=personal-color-469007
VERTEX_AI_LOCATION=asia-northeast1
VERTEX_AI_MODEL=gemini-2.5-flash

# API Configuration
MAX_IMAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3

# Security Settings
API_KEY=11A77CCB-4FA0-4CB8-A1FC-E331EAA24B2E
RATE_LIMIT_PER_MINUTE=60

# Rate Limiting (detailed)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_DIAGNOSIS=10
RATE_LIMIT_BURST=5

# Performance Settings
WORKER_COUNT=4
MAX_CONCURRENT_REQUESTS=100

# Logging Configuration
LOG_LEVEL=INFO

# Monitoring Settings
ENABLE_METRICS=true
ENABLE_TRACING=true

# Cache (if using Redis in future)
# REDIS_URL=redis://your-redis-instance

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@host:port/database

# Firebase Configuration
FIREBASE_PROJECT_ID=personal-color-app-public