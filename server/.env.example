# Server environment variables - Copy this to .env and fill in real values
# DO NOT COMMIT .env FILE WITH REAL VALUES

# 基本設定
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Vertex AI / Gemini 設定
USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=asia-northeast1
VERTEX_AI_MODEL=gemini-2.5-flash
VIRTUAL_TRY_ON_MODEL=virtual-try-on-preview-08-04
VIRTUAL_TRY_ON_SAMPLE_COUNT=1
VIRTUAL_TRY_ON_ADD_WATERMARK=true
VIRTUAL_TRY_ON_PERSON_GENERATION=allow_adult
VIRTUAL_TRY_ON_SAFETY_SETTING=block_medium_and_above
# 複数指定する場合はカンマ区切り（例: gs://bucket/top.png,gs://bucket/bottom.png）
VIRTUAL_TRY_ON_DEFAULT_PRODUCT_IMAGE_URIS=
VIRTUAL_TRY_ON_TIMEOUT_SECONDS=60

# Google AI Studio API (開発用・オプション)
# GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-google-api-key

# 画像・診断設定
MAX_IMAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3

# 機能フラグ
# 拡張診断（年代・性別推定）を有効化/無効化
ENHANCED_DIAGNOSIS_ENABLED=true

# セキュリティ・レート制限
API_KEY=your-secure-api-key-here
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_DIAGNOSIS=10
RATE_LIMIT_BURST=5

# ログ設定
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Firebase設定（オプション）
FIREBASE_PROJECT_ID=your-firebase-project-id
